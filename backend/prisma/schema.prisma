// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output          = "../src/generated/prisma"
  moduleFormat  = "cjs"
}

// =============================================================================
// ENUMS
// =============================================================================

enum UserRole {
  ADMIN
  USER

  @@map("user_role")
}

enum UserType {
  SYSTEM_ADMIN
  LANDLORD
  TENANT

  @@map("user_type_enum")
}

enum PropertyType {
  BOARDING_HOUSE
  APARTMENT_BUILDING
  CONDO
  SINGLE_FAMILY
  COMMERCIAL_MIXED
  OTHER

  @@map("property_type_enum")
}

enum UnitType {
  STUDIO
  BEDROOM
  ENTIRE_UNIT
  SHARED_ROOM
  DORM
  OTHER

  @@map("unit_type_enum")
}

enum UnitStatus {
  AVAILABLE
  NOT_AVAILABLE
  OCCUPIED
  MAINTENANCE

  @@map("unit_status_enum")
}

enum TenantStatus {
  ACTIVE
  MOVED_OUT
  BLACKLISTED

  @@map("tenant_status_enum")
}

enum LeaseType {
  MONTHLY
  DAILY
  FIXED

  @@map("lease_type_enum")
}

enum LeaseStatus {
  ACTIVE
  CLOSED
  EXPIRED

  @@map("lease_status_enum")
}

enum PaymentStatus {
  PAID
  UNPAID
  PARTIAL
  OVERDUE
  CANCELLED

  @@map("payment_status_enum")
}

enum PaymentMethod {
  CASH
  GCASH
  BANK_TRANSFER
  CARD
  OTHER

  @@map("payment_method_enum")
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED

  @@map("subscription_status_enum")
}

enum NotificationType {
  OVERDUE_ALERT
  PAYMENT_RECEIVED
  PAYMENT_REMINDER
  LEASE_REMINDER
  GENERAL

  @@map("notification_type_enum")
}

enum AuditAction {
  INSERT
  UPDATE
  DELETE

  @@map("audit_action_enum")
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  CANCELLED

  @@map("transaction_status_enum")
}

enum AddonBillingType {
  FIXED_AMENITY
  FLAT_FEE
  METERED

  @@map("addon_billing_type")
}

enum AddonFrequency {
  MONTHLY
  QUARTERLY
  ANNUAL
  ONE_TIME

  @@map("addon_frequency")
}

enum AddonBillStatus {
  UNPAID
  PAID
  PARTIAL
  WAIVED

  @@map("addon_bill_status")
}

// =============================================================================
// MODELS
// =============================================================================

model User {
  id                     String    @id @default(cuid())
  email                  String    @unique
  password               String
  firstName              String
  lastName               String
  role                   UserRole  @default(USER)
  userType               UserType  @default(LANDLORD)
  phone                  String?
  isEmailVerified        Boolean   @default(false)
  emailVerificationToken String?   @unique
  resetPasswordToken     String?   @unique
  resetPasswordExpires   DateTime?
  isActive               Boolean   @default(true)
  failedLoginAttempts    Int       @default(0)
  lockedUntil            DateTime?
  emailVerificationExpires DateTime?
  deletedAt              DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  refreshTokens          RefreshToken[]
  createdPropertyGroups  PropertyGroup[]       @relation("PropertyGroupCreatedBy")
  propertyGroupMembers   PropertyGroupMember[]
  tenantProfile          Tenant?               @relation("TenantUser")
  addresses              UserAddress[]
  notifications          Notification[]
  auditTrailEntries      AuditTrail[]
  utilityReadingsEntered UtilityReading[]      @relation("UtilityReadingReadBy")
  initiatedTransactions  PaymentTransaction[]  @relation("PaymentTransactionInitiatedBy")

  @@index([email])
  @@index([emailVerificationToken])
  @@index([resetPasswordToken])
  @@index([deletedAt])
  @@index([userType])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model UserAddress {
  id             String   @id @default(cuid())
  userId         String
  label          String
  recipientName  String?
  recipientPhone String?
  addressLine1   String
  addressLine2   String?
  city           String
  stateProvince  String?
  postalCode     String?
  country        String   @default("Philippines")
  latitude       Decimal? @db.Decimal(10, 8)
  longitude      Decimal? @db.Decimal(11, 8)
  isDefault      Boolean  @default(false)

  version   Int       @default(1)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_addresses")
}

model PropertyGroup {
  id           String @id @default(cuid())
  groupName    String
  currencyCode String @default("PHP")
  timezone     String @default("Asia/Manila")
  createdBy    String

  version   Int       @default(1)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  creator          User                  @relation("PropertyGroupCreatedBy", fields: [createdBy], references: [id])
  members          PropertyGroupMember[]
  subscriptions    Subscription[]
  properties       Property[]
  leases           Lease[]
  payments         Payment[]             @relation("PropertyGroupPayments")
  notifications    Notification[]
  unitAddonCatalog UnitAddonCatalog[]
  unitAddons       UnitAddon[]
  leaseAddonBills  LeaseAddonBill[]
  utilityReadings  UtilityReading[]

  @@index([createdBy])
  @@map("property_groups")
}

model OrgRole {
  id   String @id @default(cuid())
  code String @unique
  name String

  version   Int       @default(1)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  propertyGroupMembers PropertyGroupMember[]

  @@map("org_roles")
}

model PropertyGroupMember {
  id              String @id @default(cuid())
  propertyGroupId String
  userId          String
  roleId          String

  version   Int       @default(1)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  propertyGroup PropertyGroup @relation(fields: [propertyGroupId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  role          OrgRole       @relation(fields: [roleId], references: [id])

  @@unique([propertyGroupId, userId])
  @@index([userId])
  @@map("property_group_members")
}

model SubscriptionPlan {
  id            String  @id @default(cuid())
  planName      String  @unique
  priceMonthly  Decimal @db.Decimal(12, 2)
  propertyLimit Int     @default(0)
  unitLimit     Int     @default(0)
  tenantLimit   Int     @default(0)

  version   Int       @default(1)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  subscriptions Subscription[]

  @@map("subscription_plans")
}

model Subscription {
  id                 String             @id @default(cuid())
  propertyGroupId    String
  subscriptionPlanId String
  startedAt          DateTime
  endsAt             DateTime?
  status             SubscriptionStatus @default(ACTIVE)
  cancelledAt        DateTime?
  cancellationReason String?            @db.Text

  version   Int       @default(1)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  propertyGroup    PropertyGroup    @relation(fields: [propertyGroupId], references: [id], onDelete: Cascade)
  subscriptionPlan SubscriptionPlan @relation(fields: [subscriptionPlanId], references: [id])

  @@index([propertyGroupId, status])
  @@map("subscriptions")
}

model Property {
  id              String       @id @default(cuid())
  propertyGroupId String
  propertyType    PropertyType
  propertyName    String
  addressLine     String       @db.Text
  city           String
  province       String?
  postalCode     String?
  metadata       Json?        @db.JsonB

  version   Int       @default(1)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  propertyGroup PropertyGroup @relation(fields: [propertyGroupId], references: [id], onDelete: Cascade)
  units         Unit[]
  leases        Lease[]

  @@index([propertyGroupId])
  @@map("properties")
}

model Unit {
  id           String     @id @default(cuid())
  propertyId   String
  unitType     UnitType
  unitName     String
  monthlyRent  Decimal    @db.Decimal(12, 2)
  floorNumber  Int?
  maxOccupants Int?
  status       UnitStatus @default(AVAILABLE)
  isFeatured   Boolean    @default(false)
  metadata     Json?      @db.JsonB

  version   Int       @default(1)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  property   Property    @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  leases     Lease[]
  unitAddons UnitAddon[]

  @@index([propertyId])
  @@index([status])
  @@map("units")
}

model Tenant {
  id               String       @id @default(cuid())
  userId           String?      @unique
  firstName        String
  lastName         String
  phone            String
  email            String?
  internalNotes    String?      @db.Text
  emergencyContact Json?        @db.JsonB
  status           TenantStatus @default(ACTIVE)

  version   Int       @default(1)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user   User?   @relation("TenantUser", fields: [userId], references: [id], onDelete: SetNull)
  leases Lease[]

  @@index([status])
  @@map("tenants")
}

model Lease {
  id              String      @id @default(cuid())
  propertyGroupId String
  propertyId      String
  tenantId        String
  unitId          String
  leaseType       LeaseType
  billingDay      Int         @default(1)
  advanceMonths   Int         @default(1)
  gracePeriodDays Int         @default(3)
  moveInDate      DateTime    @db.Date
  moveOutDate     DateTime?   @db.Date
  rentAmount      Decimal     @db.Decimal(12, 2)
  securityDeposit Decimal     @db.Decimal(12, 2)
  status          LeaseStatus @default(ACTIVE)

  version   Int       @default(1)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  propertyGroup   PropertyGroup    @relation(fields: [propertyGroupId], references: [id], onDelete: Cascade)
  property        Property         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  unit            Unit             @relation(fields: [unitId], references: [id])
  payments        Payment[]
  leaseAddonBills LeaseAddonBill[]
  utilityReadings UtilityReading[]

  @@index([propertyGroupId, status])
  @@index([propertyId])
  @@index([tenantId])
  @@index([unitId, status])
  @@map("leases")
}

model Payment {
  id              String         @id @default(cuid())
  leaseId         String
  propertyGroupId String
  periodStart     DateTime       @db.Date
  periodEnd       DateTime       @db.Date
  dueDate         DateTime       @db.Date
  amountDue       Decimal        @db.Decimal(12, 2)
  amountPaid      Decimal        @default(0) @db.Decimal(12, 2)
  datePaid        DateTime?      @db.Date
  paymentMethod   PaymentMethod?
  status          PaymentStatus  @default(UNPAID)
  paymentDetails  Json?          @db.JsonB

  version   Int       @default(1)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  lease               Lease                @relation(fields: [leaseId], references: [id])
  propertyGroup       PropertyGroup       @relation("PropertyGroupPayments", fields: [propertyGroupId], references: [id])
  paymentTransactions PaymentTransaction[]

  @@unique([leaseId, periodStart])
  @@index([propertyGroupId, status, dueDate])
  @@index([leaseId])
  @@map("payments")
}

model PaymentTransaction {
  id               String            @id @default(cuid())
  paymentId        String
  initiatedBy      String?
  transactionRef   String            @unique
  externalRef      String?
  gatewayName      String
  amount           Decimal           @db.Decimal(12, 2)
  status           TransactionStatus @default(PENDING)
  failureReason    String?
  expiresAt        DateTime?
  providerResponse Json?             @db.JsonB

  version   Int       @default(1)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  payment         Payment @relation(fields: [paymentId], references: [id])
  initiatedByUser User?   @relation("PaymentTransactionInitiatedBy", fields: [initiatedBy], references: [id], onDelete: SetNull)

  @@index([paymentId])
  @@map("payment_transactions")
}

model Notification {
  id              String           @id @default(cuid())
  userId          String
  propertyGroupId String?
  type            NotificationType
  channel         String
  title           String
  body            String           @db.Text
  readAt          DateTime?

  version   Int       @default(1)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  propertyGroup PropertyGroup? @relation(fields: [propertyGroupId], references: [id], onDelete: SetNull)

  @@index([userId, readAt])
  @@index([propertyGroupId])
  @@map("notifications")
}

model AuditTrail {
  id        BigInt      @id @default(autoincrement())
  userId    String?
  action    AuditAction
  tableName String
  recordId  String
  oldValues Json?       @db.JsonB
  newValues Json?       @db.JsonB
  ipAddress String?
  requestId String?
  sessionId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tableName, recordId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_trail")
}

model UnitAddonCatalog {
  id               String           @id @default(cuid())
  propertyGroupId  String?
  name             String
  category         String
  billingType      AddonBillingType
  billingFrequency AddonFrequency?
  unitOfMeasure    String?
  defaultRate      Decimal?         @db.Decimal(12, 4)
  isActive         Boolean          @default(true)
  metadata         Json?            @db.JsonB

  version   Int       @default(1)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  propertyGroup PropertyGroup? @relation(fields: [propertyGroupId], references: [id], onDelete: Cascade)
  unitAddons    UnitAddon[]

  @@index([propertyGroupId, isActive])
  @@map("unit_addon_catalog")
}

model UnitAddon {
  id              String    @id @default(cuid())
  unitId          String
  addonCatalogId  String
  propertyGroupId String
  rate            Decimal?  @db.Decimal(12, 4)
  isIncluded      Boolean   @default(false)
  meterNumber     String?
  notes           String?   @db.Text
  effectiveFrom   DateTime  @db.Date
  effectiveUntil  DateTime? @db.Date
  metadata        Json?     @db.JsonB

  version   Int       @default(1)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  unit            Unit             @relation(fields: [unitId], references: [id], onDelete: Cascade)
  addonCatalog    UnitAddonCatalog @relation(fields: [addonCatalogId], references: [id])
  propertyGroup   PropertyGroup    @relation(fields: [propertyGroupId], references: [id])
  leaseAddonBills LeaseAddonBill[]
  utilityReadings UtilityReading[]

  @@index([unitId])
  @@index([propertyGroupId])
  @@map("unit_addons")
}

model LeaseAddonBill {
  id               String          @id @default(cuid())
  leaseId          String
  unitAddonId      String
  propertyGroupId  String
  periodStart      DateTime        @db.Date
  periodEnd        DateTime        @db.Date
  dueDate          DateTime        @db.Date
  amountDue        Decimal         @db.Decimal(12, 2)
  amountPaid       Decimal         @default(0) @db.Decimal(12, 2)
  status           AddonBillStatus @default(UNPAID)
  utilityReadingId String?
  notes            String?         @db.Text

  version   Int       @default(1)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  lease          Lease           @relation(fields: [leaseId], references: [id])
  unitAddon      UnitAddon       @relation(fields: [unitAddonId], references: [id])
  propertyGroup  PropertyGroup   @relation(fields: [propertyGroupId], references: [id])
  utilityReading UtilityReading? @relation(fields: [utilityReadingId], references: [id], onDelete: SetNull)

  @@unique([leaseId, unitAddonId, periodStart])
  @@index([propertyGroupId, status, dueDate])
  @@index([leaseId])
  @@map("lease_addon_bills")
}

model UtilityReading {
  id              String   @id @default(cuid())
  unitAddonId     String
  leaseId         String
  propertyGroupId String
  readingDate     DateTime @db.Date
  previousReading Decimal  @db.Decimal(12, 4)
  currentReading  Decimal  @db.Decimal(12, 4)
  ratePerUnit     Decimal  @db.Decimal(12, 4)
  readBy          String
  photoUrl        String?
  notes           String?  @db.Text

  version   Int       @default(1)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  unitAddon       UnitAddon        @relation(fields: [unitAddonId], references: [id])
  lease           Lease            @relation(fields: [leaseId], references: [id])
  propertyGroup   PropertyGroup     @relation(fields: [propertyGroupId], references: [id])
  readByUser      User             @relation("UtilityReadingReadBy", fields: [readBy], references: [id])
  leaseAddonBills LeaseAddonBill[]

  @@index([unitAddonId, readingDate])
  @@index([leaseId])
  @@map("utility_readings")
}
